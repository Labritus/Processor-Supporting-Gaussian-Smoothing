// format: 2b opcode, 2b %d, 2b %s, 6b Imm
// ADD: no Imm, need clear at the beginning of the new loop
// 
// BINARY  //////////// ASSEMBLER /////
12'b00_00_00_000000 // NOP

12'b11_11_01_111110 // LOADI %3, %1, -2;  Load  W[i-2]      to R3
12'b10_11_11_001010 // MULI  %3, %3, 10;  MUL   W[i-2]*K[0] to R3

12'b11_10_01_111111 // LOADI %2, %1, -1;  Load  W[i-1]      to R2
12'b10_10_10_010101 // MULI  %2, %2, 21;  MUL   W[i-1]*K[1] to R2
12'b01_11_10_000000 // ADD   %3, %2,   ;  ADD   WK+R3       to R3

12'b11_10_01_000000 // LOADI %2, %1,  0;  Load  W[i]        to R2
12'b10_10_10_011011 // MULI  %2, %2, 27;  MUL   W[i]*K[2]   to R2
12'b01_11_10_000000 // ADD   %3, %2,   ;  ADD   WK+R3       to R3

12'b11_10_01_000001 // LOADI %2, %1, -1;  Load  W[i-1]      to R2
12'b10_10_10_010101 // MULI  %2, %2, 21;  MUL   W[i-1]*K[3] to R2
12'b01_11_10_000000 // ADD   %3, %2,   ;  ADD   WK+R3       to R3

12'b11_10_01_000010 // LOADI %2, %1, -1;  Load  W[i-1]      to R2
12'b10_10_10_001010 // MULI  %2, %2, 10;  MUL   W[i-1]*K[4] to R2
12'b01_11_10_000000 // ADD   %3, %2,   ;  ADD   WK+R3       to R3

12'b0000_0000_0000  // NOP