// format: 2b opcode, 2b %d, 2b %s, 6b Imm
// ADD: no Imm, need clear at the beginning of the new loop
// 
// HEX // BINARY  //////////// ASSEMBLER /////
000    //12'b00_00_00_000000 // 00 NOP

F7E    //12'b11_11_01_111110 // 01 LOADI %3, %1, -2;  Load  W[i-2]      to R3
BCA    //12'b10_11_11_001010 // 02 MULI  %3, %3, 10;  MUL   W[i-2]*K[0] to R3

E7F    //12'b11_10_01_111111 // 03 LOADI %2, %1, -1;  Load  W[i-1]      to R2
A95    //12'b10_10_10_010101 // 04 MULI  %2, %2, 21;  MUL   W[i-1]*K[1] to R2
780    //12'b01_11_10_000000 // 05 ADD   %3, %2,   ;  ADD   WK+R3       to R3

E40    //12'b11_10_01_000000 // 06 LOADI %2, %1,  0;  Load  W[i]        to R2
A9B    //12'b10_10_10_011011 // 07 MULI  %2, %2, 27;  MUL   W[i]*K[2]   to R2
780    //12'b01_11_10_000000 // 08 ADD   %3, %2,   ;  ADD   WK+R3       to R3

E41    //12'b11_10_01_000001 // 09 LOADI %2, %1, +1;  Load  W[i+1]      to R2
A95    //12'b10_10_10_010101 // 10 MULI  %2, %2, 21;  MUL   W[i+1]*K[3] to R2
780    //12'b01_11_10_000000 // 11 ADD   %3, %2,   ;  ADD   WK+R3       to R3

E42    //12'b11_10_01_000010 // 12 LOADI %2, %1, +2;  Load  W[i+2]      to R2
A8A    //12'b10_10_10_001010 // 13 MULI  %2, %2, 10;  MUL   W[i+2]*K[4] to R2
780    //12'b01_11_10_000000 // 14 ADD   %3, %2,   ;  ADD   WK+R3       to R3

000    //12'b00_00_00_000000  // 15 NOP